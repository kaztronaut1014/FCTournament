@model IEnumerable<FCTournament.Models.Bill>
@{
    ViewData["Title"] = "Lịch sử Giao dịch";
    var paidAmounts = ViewBag.PaidAmounts as Dictionary<int, float> ?? new Dictionary<int, float>();
}

<div class="page-heading header-text">
    <div class="container"><div class="row"><div class="col-lg-12"><h3>QUẢN LÝ GIAO DỊCH</h3></div></div></div>
</div>

<div class="container py-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success fw-bold mb-4" style="border-radius: 10px;">
            <i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="bg-white p-4" style="border-radius: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
        <h5 class="fw-bold mb-4 text-primary"><i class="fa fa-file-invoice-dollar me-2"></i>Hóa đơn của tôi</h5>
        <div class="table-responsive">
            <table class="table align-middle table-hover m-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã HĐ</th>
                        <th>Giải đấu</th>
                        <th>Đội bóng</th>
                        <th>Tổng phí</th>
                        <th>Đã trả</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        float paid = paidAmounts.ContainsKey(item.Id) ? paidAmounts[item.Id] : 0;
                        float remaining = item.Fee - paid;

                        <tr>
                            <td class="fw-bold text-muted">#@item.Id</td>
                            <td class="fw-bold">@item.Tournament?.Name</td>
                            <td>@item.Team?.FullName</td>
                            <td class="text-primary fw-bold">@item.Fee.ToString("N0")đ</td>
                            <td class="text-success fw-bold">@paid.ToString("N0")đ</td>
                            <td>
                                @if (item.isPaid)
                                {
                                    <span class="badge bg-success"><i class="fa fa-check"></i> Hoàn tất</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="fa fa-clock"></i> Nợ @remaining.ToString("N0")đ</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (!item.isPaid)
                                {
                                    <a asp-action="CheckoutRemaining" asp-route-billId="@item.Id" class="btn btn-sm btn-primary fw-bold" style="border-radius: 8px;">
                                        Thanh toán nốt
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size: 13px;">@item.DatePaid.ToString("dd/MM/yyyy")</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center py-4 text-muted">Chưa có giao dịch nào!</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>