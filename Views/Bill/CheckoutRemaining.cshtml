@model FCTournament.Models.Bill
@{
    ViewData["Title"] = "Thanh toán nốt lệ phí";
    float paidAmount = ViewBag.PaidAmount;
    float remaining = ViewBag.Remaining;
}

<div class="page-heading header-text">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h3>Xác nhận thanh toán</h3>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-4 shadow-lg" style="border-radius: 20px; border: none;">
                <h4 class="fw-bold text-center text-primary mb-4">HÓA ĐƠN TRẢ SAU</h4>

                <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                    <span class="text-muted">Mã HĐ:</span>
                    <span class="fw-bold">#@Model.Id</span>
                </div>

                <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                    <span class="text-muted">Đội bóng:</span>
                    <span class="fw-bold">@Model.Team?.FullName</span>
                </div>

                <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                    <span class="text-muted">Giải đấu:</span>
                    <span class="fw-bold text-end">@Model.Tournament?.Name</span>
                </div>

                <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                    <span class="text-muted">Tổng lệ phí giải:</span>
                    <span class="fw-bold">@Model.Fee.ToString("N0") VNĐ</span>
                </div>

                <div class="d-flex justify-content-between mb-3 text-success border-bottom pb-2">
                    <span>Đã thanh toán (Cọc):</span>
                    <span>@paidAmount.ToString("N0") VNĐ</span>
                </div>

                <div class="d-flex justify-content-between mb-4 text-danger">
                    <span class="fw-bold">Cần thanh toán nốt:</span>
                    <span class="fw-bold fs-5">@remaining.ToString("N0") VNĐ</span>
                </div>

                <div class="alert alert-info text-center" style="font-size: 14px; border-radius: 10px;">
                    <i class="fa fa-info-circle"></i> Vui lòng thanh toán nốt số tiền còn lại để hoàn tất 100% lệ phí giải đấu.
                </div>

                <form asp-action="PayRemaining" method="post">
                    <input type="hidden" name="billId" value="@Model.Id" />

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold mt-2" style="border-radius: 15px; font-size: 18px;">
                        <i class="fa fa-credit-card me-2"></i> Xác nhận thanh toán nốt
                    </button>
                    <a asp-action="Index" class="btn btn-light w-100 py-2 fw-bold mt-2" style="border-radius: 15px;">
                        Hủy bỏ
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>