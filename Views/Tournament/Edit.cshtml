@model FCTournament.Models.Tournament
@{
    ViewData["Title"] = "Chỉnh sửa giải đấu";
}

<div class="page-heading header-text">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h3>Quản lý: @Model.Name</h3>
                <span class="breadcrumb"><a href="/">Trang chủ</a> > <a asp-action="Index">Giải đấu</a> > Chỉnh sửa</span>
            </div>
        </div>
    </div>
</div>

<style>
    input[type="file"] {
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
        width: 0 !important;
        height: 0 !important;
        position: absolute !important;
    }
</style>

<div class="create-form-area section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <form asp-action="@(ViewContext.RouteData.Values["action"].ToString())" method="post" enctype="multipart/form-data" class="profile-card" style="background-color: #f7f7f7; border-radius: 25px; overflow: hidden; box-shadow: 0px 10px 30px rgba(0,0,0,0.1); border: 1px solid #eee; font-family: 'Poppins', sans-serif !important;">

                    <div style="height: 0; width: 0; overflow: hidden; position: absolute; left: -9999px; visibility: hidden;">
                        <input type="file" id="bannerInput" name="bannerFile" accept="image/*" onchange="previewBanner(this)">
                        <input type="file" id="teamLogoInput" name="logoFile" accept="image/*" onchange="previewLogo(this)">
                    </div>

                    @if (ViewContext.RouteData.Values["action"].ToString() == "Edit")
                    {
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ApplicationUserId" />
                        <input type="hidden" asp-for="LogoUrl" />
                        <input type="hidden" asp-for="BannerUrl" />
                        <input type="hidden" asp-for="IsDeleted" />
                    }

                    @{
                        var bannerBg = string.IsNullOrEmpty(Model?.BannerUrl) ? "/assets/images/placeholder-banner.jpg" : Model.BannerUrl;
                    }
                    <div class="banner-section" style="background-image: url('@bannerBg'); height: 250px; position: relative; background-size: cover; background-position: center; border-bottom: 2px solid #fff; display: block; margin: 0; padding: 0;">
                        <button type="button" class="change-banner-btn btn btn-dark" onclick="triggerBannerClick()" style="position: absolute; bottom: 15px; right: 15px; border-radius: 50%; width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; background-color: rgba(0,0,0,0.7); border: 2px solid #fff; color: #fff; z-index: 10;">
                            <i class="fa fa-camera" style="font-size: 18px;"></i>
                        </button>
                    </div>

                    <div class="profile-content" style="padding: 0 30px 30px 30px; position: relative; text-align: left; display: flex; flex-direction: column;">

                        <div style="margin-top: -65px; margin-bottom: 20px; position: relative; z-index: 20; display: inline-block; cursor: pointer; width: 130px; height: 130px; margin-left: auto; margin-right: auto;" onclick="triggerLogoClick()">
                            @{
                                var logoSrc = string.IsNullOrEmpty(Model?.LogoUrl) ? "/assets/images/default-avatar.png" : Model.LogoUrl;
                            }
                            <img src="@logoSrc" id="imagePreview" alt="Tournament Logo" style="width: 130px; height: 130px; border-radius: 50%; border: 6px solid #fff; object-fit: cover; background-color: #fff; box-shadow: 0px 5px 15px rgba(0,0,0,0.2); display: block; margin: 0; padding: 0;">

                            <div class="add-overlay" style="position: absolute; bottom: 5px; right: 5px; background: #ee626b; color: #fff; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 3px solid #fff; z-index: 25;">
                                <i class="fa fa-pencil"></i>
                            </div>
                        </div>

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Tên giải đấu <span class="text-danger">*</span></label>
                                <input asp-for="Name" class="form-control" placeholder="Nhập tên giải đấu..." style="border-radius: 20px; padding: 10px 20px; font-family: 'Poppins', sans-serif !important;" required>
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Đơn vị tổ chức <span class="text-danger">*</span></label>
                                <input asp-for="Organizer" class="form-control" style="border-radius: 20px;" required>
                                <span asp-validation-for="Organizer" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Khu vực <span class="text-danger">*</span></label>
                                <select asp-for="LocationId" asp-items="ViewBag.LocationId" class="form-select" style="border-radius: 20px;" required></select>
                                <span asp-validation-for="LocationId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Ngày khai mạc <span class="text-danger">*</span></label>
                                <input asp-for="StartDate" type="date" class="form-control" style="border-radius: 20px; font-family: 'Poppins', sans-serif !important;" required>
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Số ngày dự kiến <span class="text-danger">*</span></label>
                                <input asp-for="DurationDays" type="number" min="1" class="form-control" style="border-radius: 20px;" required>
                                <span asp-validation-for="DurationDays" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Loại sân <span class="text-danger">*</span></label>
                                <select asp-for="TypeId" asp-items="ViewBag.TypeId" class="form-select" style="border-radius: 20px;" required></select>
                                <span asp-validation-for="TypeId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Thể thức thi đấu <span class="text-danger">*</span></label>
                                <select asp-for="FormatId" asp-items="ViewBag.FormatId" class="form-select" style="border-radius: 20px;" required></select>
                                <span asp-validation-for="FormatId" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Số lượng đội <span class="text-danger">*</span></label>
                                <input asp-for="Size" type="number" min="2" class="form-control" style="border-radius: 20px;" required>
                                <span asp-validation-for="Size" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Lệ phí (VNĐ) <span class="text-danger">*</span></label>
                                <input asp-for="Fees" type="number" step="1000" class="form-control" style="border-radius: 20px;" required>
                                <span asp-validation-for="Fees" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Tiền thưởng (VNĐ) <span class="text-danger">*</span></label>
                                <input asp-for="Prize" type="number" step="1000" class="form-control" style="border-radius: 20px;" required>
                                <span asp-validation-for="Prize" class="text-danger"></span>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Mô tả giải đấu</label>
                                <textarea asp-for="Description" class="form-control" rows="3" style="border-radius: 15px;"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Luật thi đấu</label>
                                <textarea asp-for="Rules" class="form-control" rows="3" style="border-radius: 15px;"></textarea>
                                <span asp-validation-for="Rules" class="text-danger"></span>
                            </div>

                            <div class="col-md-12 mb-4">
                                <div class="form-check ms-2 d-flex align-items-center">
                                    <input asp-for="needApproved" class="form-check-input me-2" type="checkbox" id="needApproved" style="width: 22px; height: 22px; cursor: pointer;">
                                    <label class="form-check-label fw-bold text-muted mt-1" for="needApproved" style="cursor: pointer; font-size: 15px;">
                                        Yêu cầu phê duyệt đội tham gia
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-12 d-flex justify-content-center flex-wrap gap-3 mt-4">
                                <button type="submit" class="btn px-4 py-2 fw-bold" style="background-color: #008af8; color: white; border-radius: 25px; text-transform: uppercase; font-family: 'Poppins', sans-serif !important;">
                                    <i class="fa fa-save me-2"></i> Lưu thay đổi
                                </button>

                                <a asp-action="Index" class="btn px-4 py-2 fw-bold" style="background-color: #6c757d; color: white; border-radius: 25px; text-decoration: none; text-transform: uppercase; font-family: 'Poppins', sans-serif !important;">
                                    Hủy bỏ
                                </a>

                                <button type="button" class="btn px-4 py-2 fw-bold" style="background-color: #ee626b; color: white; border-radius: 25px; text-transform: uppercase; font-family: 'Poppins', sans-serif !important;" onclick="if(confirm('⚠️ CẢNH BÁO: Bạn có chắc chắn muốn xóa giải đấu này không?\\n\\nMọi dữ liệu về đội bóng và lịch thi đấu sẽ bị ẩn khỏi hệ thống. Hành động này không thể hoàn tác!')) document.getElementById('deleteForm').submit();">
                                    <i class="fa fa-trash me-2"></i> Xóa giải
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
                <form id="deleteForm" asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display: none;"></form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function triggerLogoClick() { document.getElementById('teamLogoInput').click(); }
        function triggerBannerClick() { document.getElementById('bannerInput').click(); }

        function previewLogo(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) { document.getElementById('imagePreview').src = e.target.result; }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function previewBanner(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) { document.querySelector('.banner-section').style.backgroundImage = `url('${e.target.result}')`; }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}