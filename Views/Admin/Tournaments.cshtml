@model IEnumerable<FCTournament.Models.Tournament>
@{
    ViewData["Title"] = "Quản lý Giải đấu";
}

<div class="page-heading header-text">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h3>QUẢN LÝ GIẢI ĐẤU</h3>
                <span class="breadcrumb"><a asp-action="Index">Admin</a> > Tất cả giải đấu</span>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success fw-bold mb-4" style="border-radius: 10px;">@TempData["SuccessMessage"]</div>
    }

    <div class="bg-white p-4" style="border-radius: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
        <table class="table align-middle table-hover m-0">
            <thead class="table-light">
                <tr>
                    <th>Tên giải đấu</th>
                    <th>Ban tổ chức</th>
                    <th>Ngày bắt đầu</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-primary">@item.Name</td>
                        <td>@item.Organizer</td>
                        <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (item.IsFinished)
                            {
                                <span class="badge bg-secondary">Kết thúc</span>
                            }
                            else if (item.IsStarted)
                            {

                                <span class="badge bg-danger">Đang đá</span>
                            }
                            else
                            {

                                <span class="badge bg-primary">Sắp tới</span>
                            }
                        </td>
                        <td class="text-end">
                            <form asp-action="DeleteTournament" method="post" onsubmit="return confirm('⚠️ CẢNH BÁO: Bạn là Admin. Hành động này sẽ xóa vĩnh viễn giải đấu này?');">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-danger fw-bold"><i class="fa fa-trash"></i> Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>