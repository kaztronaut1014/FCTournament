@model IEnumerable<FCTournament.Models.Bill>
@{
    ViewData["Title"] = "Quản lý Giao dịch";
    var paidAmounts = ViewBag.PaidAmounts as Dictionary<int, float> ?? new Dictionary<int, float>();

    // Thống kê nhanh
    float totalRevenue = Model.Sum(b => b.Fee);
    float totalCollected = paidAmounts.Values.Sum();
}

<div class="page-heading header-text">
    <div class="container"><div class="row"><div class="col-lg-12"><h3>QUẢN LÝ GIAO DỊCH (ADMIN)</h3></div></div></div>
</div>

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card bg-primary text-white p-4" style="border-radius: 15px; border: none;">
                <h6 class="text-white-50">TỔNG DOANH THU LÝ THUYẾT</h6>
                <h2 class="fw-bold mb-0" style="color: white">@totalRevenue.ToString("N0") VNĐ</h2>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card bg-success text-white p-4" style="border-radius: 15px; border: none;">
                <h6 class="text-white-50">THỰC TẾ ĐÃ THU CỌC</h6>
                <h2 class="fw-bold mb-0" style="color: white">@totalCollected.ToString("N0") VNĐ</h2>
            </div>
        </div>
    </div>

    <div class="bg-white p-4" style="border-radius: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
        <div class="table-responsive">
            <table class="table align-middle table-hover m-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã HĐ</th>
                        <th>Thời gian</th>
                        <th>Giải đấu</th>
                        <th>Đội bóng</th>
                        <th>Tổng phí</th>
                        <th>Đã thu</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        float paid = paidAmounts.ContainsKey(item.Id) ? paidAmounts[item.Id] : 0;
                        float remaining = item.Fee - paid;

                        <tr>
                            <td class="fw-bold text-muted">#@item.Id</td>
                            <td style="font-size: 14px;">@item.DateCreate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="fw-bold text-primary">@item.Tournament?.Name</td>
                            <td class="fw-bold">@item.Team?.FullName</td>
                            <td class="fw-bold">@item.Fee.ToString("N0")đ</td>
                            <td class="text-success fw-bold">@paid.ToString("N0")đ</td>
                            <td>
                                @if (item.isPaid)
                                {
                                    <span class="badge bg-success"><i class="fa fa-check"></i> Đã thu đủ</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="fa fa-exclamation-circle"></i> Đang nợ @remaining.ToString("N0")đ</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <form asp-action="UpdateBill" method="post">
                                        <input type="hidden" name="billId" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-success fw-bold"><i class="fa fa-check"></i> Duyệt</button>
                                    </form>
                                    <form asp-action="RemoveBill" method="post" onsubmit="return confirm('Xóa hóa đơn này?');">
                                        <input type="hidden" name="billId" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger fw-bold"><i class="fa fa-times"></i> Hủy</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>