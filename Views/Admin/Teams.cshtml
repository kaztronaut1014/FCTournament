@model IEnumerable<FCTournament.Models.Team>
@{
    ViewData["Title"] = "Quản lý Đội bóng";
}

<div class="page-heading header-text">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <h3>QUẢN LÝ ĐỘI BÓNG</h3>
                <span class="breadcrumb"><a asp-action="Index">Admin</a> > Tất cả đội bóng</span>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success fw-bold mb-4" style="border-radius: 10px;">@TempData["SuccessMessage"]</div>
    }

    <div class="bg-white p-4" style="border-radius: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
        <table class="table align-middle table-hover m-0">
            <thead class="table-light">
                <tr>
                    <th>Tên Đội</th>
                    <th>Tên viết tắt</th>
                    <th>Ngày thành lập</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">
                            <img src="@(string.IsNullOrEmpty(item.Logo) ? "/assets/images/default-avatar.png" : item.Logo)" style="width: 30px; height: 30px; border-radius: 50%; object-fit: cover;" class="me-2">
                            @item.FullName
                        </td>
                        <td>@item.ShortName</td>
                        <td>@item.EstablishDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <form asp-action="DeleteTeam" method="post" onsubmit="return confirm('⚠️ Chắc chắn Xóa đội bóng này?');">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-danger fw-bold"><i class="fa fa-trash"></i> Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>