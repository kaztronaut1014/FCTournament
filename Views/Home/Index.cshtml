@{
    ViewData["Title"] = "Trang chủ";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    .header-text h6 {
        color: #008af8 !important;
    }

    .search-input button {
        background-color: #008af8 !important;
        border-color: #008af8 !important;
    }

        .search-input button:hover {
            background-color: #0066b8 !important;
        }

    .features .item .image {
        background-color: rgba(0, 138, 248, 0.1) !important;
    }

    .subscribe form button {
        background-color: #008af8 !important;
    }

        .subscribe form button:hover {
            background-color: #0066b8 !important;
        }

    .cta .main-button a {
        background-color: #008af8 !important;
        border-color: #008af8 !important;
    }

        .cta .main-button a:hover {
            background-color: #0066b8 !important;
        }

    .owl-carousel .owl-dots .owl-dot.active span, .owl-carousel .owl-dots .owl-dot:hover span {
        background: #008af8 !important;
    }

    /* --- ADDED: Styling cho các FontAwesome Icons mới trong phần features --- */
    /* Giả sử theme của bạn có circular styling chuẩn, chúng ta chỉ cần chỉnh icon */
    .features .item .image i {
        font-size: 36px; /* Kích thước icon lớn */
        color: #008af8 !important; /* user's primary blue */
        line-height: 90px; /* Căn giữa icon theo chiều dọc trong vòng tròn 90px tiêu chuẩn */
        text-align: center;
        display: block;
    }
    /* Chỉnh lại container của icon để nó luôn là vòng tròn và căn giữa đẹp mắt */
    .features .item .image {
        width: 90px !important;
        height: 90px !important;
        border-radius: 50% !important; /* Vòng tròn */
        margin: 0 auto 30px !important; /* Căn giữa div và tạo khoảng cách dưới */
        display: block !important;
        padding: 0 !important; /* Xóa padding cũ để icon căn giữa chuẩn */
        overflow: hidden;
    }
</style>

<div class="main-banner">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 align-self-center">
                <div class="caption header-text">
                    <h6>CHÀO MỪNG ĐẾN VỚI FC TOURNAMENT</h6>
                    <h2>QUẢN LÝ GIẢI ĐẤU BÓNG ĐÁ HÀNG ĐẦU</h2>
                    <p>Chúng tôi cung cấp giải pháp quản lý toàn diện cho các giải đấu bóng đá, giúp bạn dễ dàng tổ chức và theo dõi các trận đấu một cách hiệu quả.</p>
                    <div class="search-input">
                        <form id="search" action="#">
                            <input type="text" placeholder="Tìm kiếm giải đấu, đội bóng..." id='searchText' name="searchKeyword" />
                            <button role="button">Tìm kiếm</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 offset-lg-1 p-0">
                <div class="right-image">
                    <div class="owl-carousel owl-banner">
                        <div class="item">
                            <img src="~/assets/images/svd.jpg" alt="Home" style="border-radius: 25px;">
                        </div>
                        <div class="item">
                            <img src="~/assets/images/home.jpg" alt="Tournament" style="border-radius: 25px;">
                        </div>
                        <div class="item">
                            <img src="~/assets/images/svd1.jpg" alt="Football" style="border-radius: 25px;">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="features" style="margin-bottom: 80px;">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 col-md-6">
                <a asp-controller="Tournament" asp-action="Create">
                    <div class="item">
                        <div class="image">
                            <i class="fa fa-trophy"></i>
                        </div>
                        <h4>Tổ chức giải đấu</h4>
                    </div>
                </a>
            </div>

            <div class="col-lg-4 col-md-6">
                <a asp-controller="Team" asp-action="Index">
                    <div class="item">
                        <div class="image">
                            <i class="fa fa-users"></i>
                        </div>
                        <h4>Tạo Đội bóng</h4>
                    </div>
                </a>
            </div>

            <div class="col-lg-4 col-md-6">
                <a asp-controller="Tournament" asp-action="Index">
                    <div class="item">
                        <div class="image">
                            <i class="fa fa-calendar-check"></i>
                        </div>
                        <h4>Tham gia thi đấu</h4>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="section cta">
    <div class="container">
        <div class="row">
            <div class="col-lg-5">
                <div class="shop">
                    <div class="row">
                        <div class="col-lg-12">
                            <div class="section-heading">
                                <h6>TÍNH NĂNG CHUYÊN NGHIỆP</h6>
                                <h2>Nâng tầm giải đấu của bạn với Hệ thống tự động tối ưu nhất!</h2>
                            </div>
                            <p>Công cụ của chúng tôi hỗ trợ từ giải đấu phủi đến bán chuyên nghiệp một cách minh bạch và dễ dàng.</p>
                            <div class="main-button">
                                <a asp-controller="Tournament" asp-action="Create">TẠO GIẢI NGAY</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 offset-lg-2 align-self-end">
                <div class="subscribe">
                    <div class="row">
                        <div class="col-lg-12">
                            <div class="section-heading">
                                <h6>ĐĂNG KÝ THÀNH VIÊN</h6>
                                <h2>Nhận ngay Mã giảm giá 20% cho phí tổ chức giải đấu đầu tiên!</h2>
                            </div>
                            <div class="search-input">
                                <form id="subscribe" action="#">
                                    <input type="email" class="form-control" id="exampleInputEmail1" placeholder="Nhập email của bạn...">
                                    <button type="submit">ĐĂNG KÝ NGAY</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function(){
            if($('.owl-banner').length > 0) {
                $('.owl-carousel').owlCarousel({
                    items: 1,
                    loop: true,
                    autoplay: true,
                    autoplayTimeout: 5000,
                    animateOut: 'fadeOut',
                    animateIn: 'fadeIn',
                    nav: false,
                    dots: true
                });
            }
        });
    </script>
}